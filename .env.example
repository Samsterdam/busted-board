# ─────────────────────────────────────────────────────────────────────────────
# Analytics (PostHog — posthog.com, free up to 1M events/mo)
# NEXT_PUBLIC_POSTHOG_KEY: Project API key (phc_...) from Project Settings → API Keys
# NEXT_PUBLIC_POSTHOG_HOST: Optional — defaults to https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ─────────────────────────────────────────────────────────────────────────────
# Rate limiting (Upstash Redis — optional, free tier at upstash.com)
# Leave blank to skip rate limiting in local dev. Required in production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Keep-alive cron (Vercel Cron → /api/health). Pings Redis weekly so the
# free-tier Upstash DB isn't archived for inactivity. Set CRON_SECRET to any
# random string in Vercel; Cron sends it automatically as a Bearer token.
CRON_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Ad providers
#
# Only ONE full-site manager may be live at a time (AdSense, GAM, Ezoic,
# Mediavine, Raptive, Monumetric) — running two violates every network's TOS.
# Pick it with NEXT_PUBLIC_AD_PRIMARY. Header-bidding (Prebid + Amazon TAM),
# native (Taboola/Outbrain), contextual (Media.net) and direct (Carbon/BSA)
# providers compose on top and load whenever their own vars are set.
#
# Leave a provider's vars blank to keep it off. In `next dev` every slot shows
# a labeled placeholder regardless, so you can design layout without live ads.
# ─────────────────────────────────────────────────────────────────────────────

# Which primary manager is live: adsense | gam | ezoic | mediavine | raptive
#   | monumetric | none (header-bidding/native only) | off (no ads at all)
NEXT_PUBLIC_AD_PRIMARY=adsense

# Require explicit consent before any ad script loads (EU/GDPR). true | false
NEXT_PUBLIC_AD_REQUIRE_CONSENT=false

# ── Google AdSense ───────────────────────────────────────────────────────────
NEXT_PUBLIC_ADSENSE_CLIENT=          # ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_BANNER=     # ad-unit slot id
NEXT_PUBLIC_ADSENSE_SLOT_INLINE=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=
NEXT_PUBLIC_ADSENSE_SLOT_FOOTER=
NEXT_PUBLIC_ADSENSE_SLOT_STICKY=

# ── Google Ad Manager (GPT) ──────────────────────────────────────────────────
NEXT_PUBLIC_GAM_NETWORK_CODE=        # your GAM network code

# ── Ezoic (standalone integration) ───────────────────────────────────────────
NEXT_PUBLIC_EZOIC_ENABLED=false
NEXT_PUBLIC_EZOIC_PH_BANNER=         # numeric placeholder id from Ezoic
NEXT_PUBLIC_EZOIC_PH_INLINE=
NEXT_PUBLIC_EZOIC_PH_SIDEBAR=
NEXT_PUBLIC_EZOIC_PH_FOOTER=
NEXT_PUBLIC_EZOIC_PH_STICKY=

# ── Mediavine ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MEDIAVINE_SITE_ID=       # site slug from scripts.mediavine.com

# ── Raptive (AdThrive) ───────────────────────────────────────────────────────
NEXT_PUBLIC_RAPTIVE_SITE_ID=

# ── Monumetric ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_MONUMETRIC_SITE_ID=
NEXT_PUBLIC_MONUMETRIC_PROPERTY=

# ── Prebid.js header bidding (set ENABLED + at least one bidder) ──────────────
NEXT_PUBLIC_PREBID_ENABLED=false
NEXT_PUBLIC_PREBID_IX_SITE_ID=            # Index Exchange
NEXT_PUBLIC_PREBID_OPENX_UNIT=            # OpenX ad unit id
NEXT_PUBLIC_PREBID_OPENX_DELDOMAIN=       # OpenX delivery domain
NEXT_PUBLIC_PREBID_PUBMATIC_PUBID=        # PubMatic publisher id
NEXT_PUBLIC_PREBID_PUBMATIC_ADSLOT=
NEXT_PUBLIC_PREBID_CRITEO_NETWORK=        # Criteo network id (number)
NEXT_PUBLIC_PREBID_SOVRN_TAGID=           # Sovrn tag id

# ── Amazon Publisher Services (TAM/APS) ──────────────────────────────────────
NEXT_PUBLIC_AMAZON_TAM_PUB_ID=

# ── Media.net (contextual) ───────────────────────────────────────────────────
NEXT_PUBLIC_MEDIANET_CID=
NEXT_PUBLIC_MEDIANET_CRID_BANNER=    # per-unit CRID
NEXT_PUBLIC_MEDIANET_CRID_INLINE=
NEXT_PUBLIC_MEDIANET_CRID_SIDEBAR=
NEXT_PUBLIC_MEDIANET_CRID_FOOTER=
NEXT_PUBLIC_MEDIANET_CRID_STICKY=

# ── Taboola (native) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_TABOOLA_PUBLISHER=       # publisher account name

# ── Outbrain (native) ────────────────────────────────────────────────────────
NEXT_PUBLIC_OUTBRAIN_ENABLED=false
NEXT_PUBLIC_OUTBRAIN_WIDGET_INLINE=  # data-widget-id
NEXT_PUBLIC_OUTBRAIN_WIDGET_FOOTER=

# ── Carbon Ads (single sidebar unit, tech audiences) ─────────────────────────
NEXT_PUBLIC_CARBON_SERVE=
NEXT_PUBLIC_CARBON_PLACEMENT=

# ── BuySellAds ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_BSA_ENABLED=false
NEXT_PUBLIC_BSA_ZONE_SIDEBAR=        # zone id
NEXT_PUBLIC_BSA_ZONE_INLINE=
